{
	"name": "eclipsa",
	"displayName": "Eclipsa",
	"publisher": "yumma-css",
	"version": "0.1.1",
	"description": "A variant of the Ariake Dark theme.",
	"keywords": [
		"ariake",
		"color-theme",
		"dark",
		"eclipsa",
		"theme",
		"yummacss"
	],
	"categories": [
		"Themes"
	],
	"galleryBanner": {
		"color": "#151724",
		"theme": "dark"
	},
	"icon": "icon.png",
	"homepage": "https://yummacss.com",
	"license": "MIT",
	"author": "Renildo Pereira",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/yummacss/eclipsa"
	},
	"scripts": {
		"lint": "biome check --write",
		"build": "vsce package --no-dependencies"
	},
	"engines": {
